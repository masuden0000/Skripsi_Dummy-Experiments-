# Copy this file to .env and fill with your own values
# Required values are marked per section. Some runtime values below have defaults in code.

# LLM Configuration (required)
GROQ_API_KEY=your_groq_api_key_here
MODEL_NAME=llama-3.3-70b-versatile
TEMPERATURE=0.7

# Embedding Configuration (required for RAG retrieval / Supabase ingest)
GOOGLE_API_KEY=your_google_api_key_here
EMBEDDING_MODEL_NAME=gemini-embedding-001

# Supabase Configuration (required)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Chat Server Configuration (optional with defaults)
CHAT_HOST=127.0.0.1
CHAT_PORT=8000

# RAG Configuration (optional with defaults)
RAG_TOP_K=5
RAG_MIN_CONTEXT_SIMILARITY=0.45
