# Copy this file to .env and fill with your own values
# All values below are REQUIRED - no defaults are used in code

# LLM Configuration (required)
GOOGLE_API_KEY=your_google_api_key_here
MODEL_NAME=gemini-2.5-flash
TEMPERATURE=0.7
EMBEDDING_MODEL_NAME=gemini-embedding-001

# Supabase Configuration (required)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Chat Server Configuration (optional with defaults)
CHAT_HOST=127.0.0.1
CHAT_PORT=8000

# RAG Configuration (optional with defaults)
RAG_TOP_K=5
RAG_MIN_CONTEXT_SIMILARITY=0.45

# Evaluation Configuration (required for generate_testset and eval commands)
OPENAI_API_KEY=your_openai_api_key_here
RAGAS_TESTSET_SIZE=20
