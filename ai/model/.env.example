# Copy this file to ai/.env and fill with your own values
# Required values are marked per section. Some runtime values below have defaults in code.

# Groq keys (5 slots) — model: llama-3.3-70b-versatile
# RotaSi otomatis jika satu key limit/error
GROQ_API_KEY=your_groq_api_key_here
GROQ_API_KEY_2=
GROQ_API_KEY_3=
GROQ_API_KEY_4=
GROQ_API_KEY_5=

MODEL_NAME=llama-3.3-70b-versatile
GEMINI_MODEL_NAME=gemini-2.5-flash
TEMPERATURE=0

# Gemini keys (5 slots) — embedding model: gemini-embedding-001
# RotaSi otomatis jika satu key limit/error
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_API_KEY_2=
GOOGLE_API_KEY_3=
GOOGLE_API_KEY_4=
GOOGLE_API_KEY_5=

EMBEDDING_MODEL_NAME=gemini-embedding-001

# Supabase Configuration (required)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Chat Server Configuration (optional with defaults)
CHAT_HOST=127.0.0.1
CHAT_PORT=8000

# RAG Configuration (optional with defaults)
RAG_TOP_K=5
RAG_MIN_CONTEXT_SIMILARITY=0.45
